{
  "info": {
    "name": "Genc Store — Orders",
    "description": "Collection for testing order endpoints. Run the Login request first — the test script will automatically save the token to the `token` collection variable, which is then injected into every subsequent request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string",
      "description": "Base URL of the running API server."
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token — populated automatically by the Login request's test script. Do not edit manually."
    },
    {
      "key": "order_id",
      "value": "",
      "type": "string",
      "description": "Populated automatically by the Place Order request's test script."
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "0. Auth — Login (sets token)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"Password123!\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": ["{{base_url}}"],
          "path": ["auth", "login"]
        },
        "description": "Authenticate and store the JWT token. Change the credentials to match a seeded user.\n\nThe test script below automatically saves the returned `access_token` to the collection variable `token`, so all other requests in this collection will be authenticated without any manual copy-paste."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "",
              "pm.test('Login successful', function () {",
              "    pm.response.to.have.status(200);",
              "    pm.expect(json).to.have.property('access_token');",
              "});",
              "",
              "if (json.access_token) {",
              "    pm.collectionVariables.set('token', json.access_token);",
              "    console.log('Token saved to collection variable.');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "1. Place Order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"items\": [\n    { \"product_id\": 1, \"quantity\": 1 },\n    { \"product_id\": 3, \"quantity\": 2 }\n  ],\n  \"payment_type\": \"card\",\n  \"shipping_address_id\": 1,\n  \"billing_address_id\": 1\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/orders/",
          "host": ["{{base_url}}"],
          "path": ["orders", ""]
        },
        "description": "Place a new order. Uses the token saved by the Login request.\n\nThe test script saves the returned order `id` to the `order_id` collection variable, which is used by the Get Single Order and Cancel Order requests below."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "",
              "pm.test('Order created with status 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Status is pending', function () {",
              "    pm.expect(json.status).to.eql('pending');",
              "});",
              "",
              "pm.test('Response has items', function () {",
              "    pm.expect(json.items).to.be.an('array').that.is.not.empty;",
              "});",
              "",
              "if (json.id) {",
              "    pm.collectionVariables.set('order_id', json.id);",
              "    console.log('order_id saved:', json.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Get My Order History",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/orders/me?page=1&limit=10",
          "host": ["{{base_url}}"],
          "path": ["orders", "me"],
          "query": [
            {
              "key": "page",
              "value": "1",
              "description": "Page number (>= 1)"
            },
            {
              "key": "limit",
              "value": "10",
              "description": "Items per page (1-100)"
            }
          ]
        },
        "description": "Returns a paginated list of the authenticated user's orders, newest first. Each item includes a computed `total_amount` and `item_count` — no line-item detail."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "",
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is paginated', function () {",
              "    pm.expect(json).to.have.all.keys('total_items', 'page', 'items');",
              "    pm.expect(json.items).to.be.an('array');",
              "});",
              "",
              "pm.test('Each item has expected fields', function () {",
              "    json.items.forEach(function (order) {",
              "        pm.expect(order).to.have.all.keys('id', 'status', 'payment_type', 'created_at', 'total_amount', 'item_count');",
              "    });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Get My Order by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/orders/me/{{order_id}}",
          "host": ["{{base_url}}"],
          "path": ["orders", "me", "{{order_id}}"]
        },
        "description": "Returns the full detail of the order created in step 1. Uses the `order_id` variable saved automatically.\n\nReturns 403 if the order belongs to a different user, 404 if it doesn't exist."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "",
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has all detail fields', function () {",
              "    pm.expect(json).to.have.all.keys('id', 'status', 'payment_type', 'shipping_address_id', 'billing_address_id', 'created_at', 'items');",
              "    pm.expect(json.items).to.be.an('array').that.is.not.empty;",
              "});",
              "",
              "pm.test('ID matches', function () {",
              "    pm.expect(json.id).to.eql(parseInt(pm.collectionVariables.get('order_id')));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Cancel My Order",
      "request": {
        "method": "PATCH",
        "header": [],
        "url": {
          "raw": "{{base_url}}/orders/me/{{order_id}}/cancel",
          "host": ["{{base_url}}"],
          "path": ["orders", "me", "{{order_id}}", "cancel"]
        },
        "description": "Cancels the order created in step 1. Only works for orders in `pending` or `confirmed` status.\n\n- Returns 409 if the order is already past cancellation (e.g. `in_delivery`, `completed`).\n- Returns 403 if the order belongs to a different user.\n- Returns 404 if the order doesn't exist."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "",
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Status is cancelled', function () {",
              "    pm.expect(json.status).to.eql('cancelled');",
              "});",
              "",
              "pm.test('ID matches', function () {",
              "    pm.expect(json.id).to.eql(parseInt(pm.collectionVariables.get('order_id')));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "ERR — Cancel Already Cancelled Order (409)",
      "request": {
        "method": "PATCH",
        "header": [],
        "url": {
          "raw": "{{base_url}}/orders/me/{{order_id}}/cancel",
          "host": ["{{base_url}}"],
          "path": ["orders", "me", "{{order_id}}", "cancel"]
        },
        "description": "Run this immediately after step 4. Attempting to cancel an already-cancelled order should return 409 Conflict."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Returns 409 for already-cancelled order', function () {",
              "    pm.response.to.have.status(409);",
              "});",
              "",
              "pm.test('Error message mentions status', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.detail).to.include('cancelled');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "ERR — Get Order Belonging to Another User (403)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/orders/me/1",
          "host": ["{{base_url}}"],
          "path": ["orders", "me", "1"]
        },
        "description": "Attempt to access order ID 1 (seeded, belongs to a different user). Should return 403 if the logged-in user does not own it. Change the ID as needed."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Returns 403 for unowned order', function () {",
              "    pm.response.to.have.status(403);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "ERR — Get Non-Existent Order (404)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/orders/me/999999",
          "host": ["{{base_url}}"],
          "path": ["orders", "me", "999999"]
        },
        "description": "Request a non-existent order ID. Should return 404."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Returns 404 for missing order', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "ERR — No Token (401)",
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/orders/me",
          "host": ["{{base_url}}"],
          "path": ["orders", "me"]
        },
        "description": "Request without an Authorization header. Should return 401."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Returns 401 without token', function () {",
              "    pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}