{
  "info": {
    "name": "Genc Store — Users",
    "description": "Full workflow for testing user profile and address endpoints. Run request 0 (Login) first — the test script saves the token automatically. All subsequent requests use it via the collection-level Bearer auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Populated automatically by the Login request."
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string",
      "description": "Populated automatically by the Login request (from the profile fetch)."
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "0. Login (sets token)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"Password123!\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": ["{{base_url}}"],
          "path": ["auth", "login"]
        },
        "description": "Authenticate with a seeded user. The test script saves the JWT to the `token` collection variable — no manual copy-paste needed.\n\nChange the credentials to match any seeded user you want to test with."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login successful', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "if (json.access_token) {",
              "    pm.collectionVariables.set('token', json.access_token);",
              "    console.log('Token saved.');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "1. Get My Profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/me",
          "host": ["{{base_url}}"],
          "path": ["users", "me"]
        },
        "description": "Fetches the profile of the currently authenticated user. Also saves the user's `id` to the `user_id` collection variable for use in later requests."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Response has expected fields', function () {",
              "    pm.expect(json).to.have.all.keys('id', 'email', 'first_name', 'last_name', 'phone', 'role', 'is_active', 'created_at', 'updated_at');",
              "});",
              "",
              "if (json.id) {",
              "    pm.collectionVariables.set('user_id', json.id);",
              "    console.log('user_id saved:', json.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Update My Profile",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"first_name\": \"Alicia\",\n  \"phone\": \"+40799999999\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/users/me",
          "host": ["{{base_url}}"],
          "path": ["users", "me"]
        },
        "description": "Partially updates the authenticated user's profile. Only the fields in the body are changed — omitted fields are left untouched."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('first_name updated', function () {",
              "    pm.expect(json.first_name).to.eql('Alicia');",
              "});",
              "",
              "pm.test('phone updated', function () {",
              "    pm.expect(json.phone).to.eql('+40799999999');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Update Email (valid, unique)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"alicia.updated@example.com\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/users/me",
          "host": ["{{base_url}}"],
          "path": ["users", "me"]
        },
        "description": "Updates only the email to a new unique value. Should succeed with 200."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Email updated', function () {",
              "    pm.expect(pm.response.json().email).to.eql('alicia.updated@example.com');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Set Address (first time — creates it)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"street\": \"123 Main St\",\n  \"city\": \"Bucharest\",\n  \"state\": \"Ilfov\",\n  \"postal_code\": \"010101\",\n  \"country\": \"Romania\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/users/me/address",
          "host": ["{{base_url}}"],
          "path": ["users", "me", "address"]
        },
        "description": "If the user has no address yet, this creates one. If they already have one, it replaces it. Same endpoint either way."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Response has all address fields', function () {",
              "    pm.expect(json).to.have.all.keys('street', 'city', 'state', 'postal_code', 'country');",
              "});",
              "",
              "pm.test('Street matches', function () {",
              "    pm.expect(json.street).to.eql('123 Main St');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "5. Update Address (replaces existing)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"street\": \"456 New Avenue\",\n  \"city\": \"Cluj-Napoca\",\n  \"state\": \"Cluj\",\n  \"postal_code\": \"400001\",\n  \"country\": \"Romania\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/users/me/address",
          "host": ["{{base_url}}"],
          "path": ["users", "me", "address"]
        },
        "description": "Runs the same PUT endpoint again with a different address. Since an address now exists (from step 4), this will update it in place. Verifies idempotency of PUT."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Street replaced', function () {",
              "    pm.expect(json.street).to.eql('456 New Avenue');",
              "});",
              "",
              "pm.test('City replaced', function () {",
              "    pm.expect(json.city).to.eql('Cluj-Napoca');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Get Users (paginated)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/?page=1&limit=10",
          "host": ["{{base_url}}"],
          "path": ["users", ""],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        },
        "description": "Lists all users, paginated."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Response is paginated', function () {",
              "    pm.expect(json).to.have.all.keys('total_items', 'page', 'items');",
              "    pm.expect(json.items).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "7. Get User by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/{{user_id}}",
          "host": ["{{base_url}}"],
          "path": ["users", "{{user_id}}"]
        },
        "description": "Fetches a user by the `user_id` saved from step 1."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('ID matches', function () {",
              "    pm.expect(pm.response.json().id).to.eql(parseInt(pm.collectionVariables.get('user_id')));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "ERR — Update Email Already Taken (409)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/users/me",
          "host": ["{{base_url}}"],
          "path": ["users", "me"]
        },
        "description": "Attempts to change the email to one already used by another seeded user. Should return 409. Change the email to match an existing seeded user in your DB."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Returns 409 for taken email', function () {",
              "    pm.response.to.have.status(409);",
              "});",
              "",
              "pm.test('Error message mentions email', function () {",
              "    pm.expect(pm.response.json().detail).to.include('already in use');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "ERR — Address missing required field (422)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"street\": \"123 Main St\",\n  \"city\": \"Bucharest\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/users/me/address",
          "host": ["{{base_url}}"],
          "path": ["users", "me", "address"]
        },
        "description": "Sends an incomplete address body (missing state, postal_code, country). Should return 422."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Returns 422 for missing fields', function () {",
              "    pm.response.to.have.status(422);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "ERR — Get Non-Existent User (404)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/999999",
          "host": ["{{base_url}}"],
          "path": ["users", "999999"]
        },
        "description": "Requests a user ID that does not exist. Should return 404."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Returns 404', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "ERR — No Token (401)",
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/me",
          "host": ["{{base_url}}"],
          "path": ["users", "me"]
        },
        "description": "Request without an Authorization header. Should return 401."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Returns 401 without token', function () {",
              "    pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}