{
  "POST /orders": {
    "happy_path": {
      "description": "Valid order with two products",
      "request": {
        "items": [
          { "product_id": 1, "quantity": 2 },
          { "product_id": 3, "quantity": 1 }
        ],
        "payment_type": "card",
        "shipping_address_id": 1,
        "billing_address_id": 1
      },
      "expected_status": 201
    },

    "single_item_cash": {
      "description": "Single item with cash payment",
      "request": {
        "items": [
          { "product_id": 2, "quantity": 1 }
        ],
        "payment_type": "cash",
        "shipping_address_id": 1,
        "billing_address_id": 2
      },
      "expected_status": 201
    },

    "error_empty_items": {
      "description": "Empty items list — fails DTO validation",
      "request": {
        "items": [],
        "payment_type": "card",
        "shipping_address_id": 1,
        "billing_address_id": 1
      },
      "expected_status": 422
    },

    "error_duplicate_product_ids": {
      "description": "Same product_id appears twice — fails model_validator",
      "request": {
        "items": [
          { "product_id": 1, "quantity": 2 },
          { "product_id": 1, "quantity": 3 }
        ],
        "payment_type": "card",
        "shipping_address_id": 1,
        "billing_address_id": 1
      },
      "expected_status": 422
    },

    "error_invalid_quantity": {
      "description": "Quantity of 0 — fails Field(gt=0)",
      "request": {
        "items": [
          { "product_id": 1, "quantity": 0 }
        ],
        "payment_type": "card",
        "shipping_address_id": 1,
        "billing_address_id": 1
      },
      "expected_status": 422
    },

    "error_negative_quantity": {
      "description": "Negative quantity — fails Field(gt=0)",
      "request": {
        "items": [
          { "product_id": 1, "quantity": -5 }
        ],
        "payment_type": "card",
        "shipping_address_id": 1,
        "billing_address_id": 1
      },
      "expected_status": 422
    },

    "error_invalid_product_id": {
      "description": "product_id of 0 — fails Field(gt=0)",
      "request": {
        "items": [
          { "product_id": 0, "quantity": 1 }
        ],
        "payment_type": "card",
        "shipping_address_id": 1,
        "billing_address_id": 1
      },
      "expected_status": 422
    },

    "error_invalid_payment_type": {
      "description": "Payment type not in Literal['cash', 'card']",
      "request": {
        "items": [
          { "product_id": 1, "quantity": 1 }
        ],
        "payment_type": "crypto",
        "shipping_address_id": 1,
        "billing_address_id": 1
      },
      "expected_status": 422
    },

    "error_product_not_found": {
      "description": "Product ID does not exist in DB — raises ProductNotFoundException",
      "request": {
        "items": [
          { "product_id": 99999, "quantity": 1 }
        ],
        "payment_type": "card",
        "shipping_address_id": 1,
        "billing_address_id": 1
      },
      "expected_status": 404
    },

    "error_product_not_active": {
      "description": "Product exists but is_active=false — raises ProductNotActiveException",
      "request": {
        "items": [
          { "product_id": 5, "quantity": 1 }
        ],
        "payment_type": "card",
        "shipping_address_id": 1,
        "billing_address_id": 1
      },
      "expected_status": 409,
      "note": "Use a product_id that is seeded as inactive in your DB"
    },

    "error_insufficient_stock": {
      "description": "Requested quantity exceeds available stock — raises InsufficientStockException",
      "request": {
        "items": [
          { "product_id": 1, "quantity": 99999 }
        ],
        "payment_type": "card",
        "shipping_address_id": 1,
        "billing_address_id": 1
      },
      "expected_status": 409
    },

    "error_missing_token": {
      "description": "No Authorization header — rejected by middleware",
      "request": {
        "items": [
          { "product_id": 1, "quantity": 1 }
        ],
        "payment_type": "card",
        "shipping_address_id": 1,
        "billing_address_id": 1
      },
      "expected_status": 401,
      "note": "Send this request without the Authorization header"
    },

    "error_missing_required_field": {
      "description": "Missing payment_type field entirely",
      "request": {
        "items": [
          { "product_id": 1, "quantity": 1 }
        ],
        "shipping_address_id": 1,
        "billing_address_id": 1
      },
      "expected_status": 422
    }
  }
}
