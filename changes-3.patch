diff --git a/src/api/services/address_service.py b/src/api/services/address_service.py
new file mode 100644
index 0000000..15c16da
--- /dev/null
+++ b/src/api/services/address_service.py
@@ -0,0 +1,84 @@
+from fastapi import Depends
+from sqlalchemy.exc import SQLAlchemyError
+from sqlalchemy.orm import Session
+
+from src.db.database import get_db
+from src.db.schema.address import Address
+from src.db.schema.user import User
+from src.models.user import AddressDTO, AddressResponseDTO
+from src.utils.exceptions import AddressNotFoundException, UserNotFoundException
+
+
+class AddressService:
+    def __init__(self, db: Session):
+        self.db = db
+
+    def list_addresses(self, user_id: int) -> list[AddressResponseDTO]:
+        addresses = (
+            self.db.query(Address)
+            .filter(Address.user_id == user_id, Address.is_active == True)
+            .all()
+        )
+        return [AddressResponseDTO.model_validate(a) for a in addresses]
+
+    def create_address(self, user_id: int, data: AddressDTO) -> AddressResponseDTO:
+        if not self.db.query(User).filter(User.id == user_id).first():
+            raise UserNotFoundException(user_id)
+
+        address = Address(user_id=user_id, **data.model_dump())
+        self.db.add(address)
+
+        try:
+            self.db.commit()
+            self.db.refresh(address)
+        except SQLAlchemyError:
+            self.db.rollback()
+            raise
+
+        return AddressResponseDTO.model_validate(address)
+
+    def update_address(self, user_id: int, address_id: int, data: AddressDTO) -> AddressResponseDTO:
+        address = (
+            self.db.query(Address)
+            .filter(Address.id == address_id, Address.user_id == user_id, Address.is_active == True)
+            .first()
+        )
+
+        if not address:
+            raise AddressNotFoundException(address_id)
+
+        for field, value in data.model_dump().items():
+            setattr(address, field, value)
+
+        try:
+            self.db.commit()
+            self.db.refresh(address)
+        except SQLAlchemyError:
+            self.db.rollback()
+            raise
+
+        return AddressResponseDTO.model_validate(address)
+
+    def delete_address(self, user_id: int, address_id: int) -> dict:
+        address = (
+            self.db.query(Address)
+            .filter(Address.id == address_id, Address.user_id == user_id, Address.is_active == True)
+            .first()
+        )
+
+        if not address:
+            raise AddressNotFoundException(address_id)
+
+        address.is_active = False
+
+        try:
+            self.db.commit()
+        except SQLAlchemyError:
+            self.db.rollback()
+            raise
+
+        return {"message": f"Address with id {address_id} successfully deleted."}
+
+
+def get_address_service(db: Session = Depends(get_db)) -> AddressService:
+    return AddressService(db)
